flowchart TD

    Player_Java["☕ Java版プレイヤー<br>25565/TCP"]
    Player_Bedrock["🪨 Bedrock版プレイヤー<br>19132/UDP"]

    subgraph GCE["GCE: mc-proxy-1 (e2-medium)<br>静的IP 35.200.78.252"]
        direction TB
        subgraph Compose["Docker Compose — host network"]
            Nginx["nginx-stream<br>25565/TCP → 127.0.0.1:25577"]
            Velocity["Velocity 3.4<br>127.0.0.1:25577"]
            Socat["socat-bedrock<br>UDP4-LISTEN:19132,fork<br>→ 100.107.122.45:19132"]
            Nginx --> Velocity
        end
        Tailscaled["tailscaled (systemd)<br>gce-mc-proxy: 100.124.222.31"]
    end

