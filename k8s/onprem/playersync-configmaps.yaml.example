# ============================================================
# PlayersSync mod 設定 ConfigMap テンプレート
#
# ⚠️ 注意: 2026/05 統合により Survival+Lobby+Industry → Survival 統合の単一サーバー構成に移行。
#    単一サーバーではプレイヤー間同期(playersync)は不要なため、本ファイルの ConfigMap は非アクティブ。
#    将来サーバーを分割する際に参照用として保持。
#
# 元の構成 (3サーバー):
#   - Lobby (Server_id=1) → 廃止
#   - Survival (Server_id=2) → 唯一の統合サーバーに
#   - Industry (Server_id=3) → Survival に統合
# ============================================================
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: survival-playersync-cm
  namespace: minecraft
  labels:
    app.kubernetes.io/name: minecraft-java
    app.kubernetes.io/component: survival
    app.kubernetes.io/managed-by: kubectl
    env: prod
data:
  playersync-common.toml: |
    #General settings
    [general]
    	host = "mariadb.minecraft-data.svc.cluster.local"
    	db_port = 3306
    	use_ssl = false
    	user_name = "playersync"
    	password = "REPLACE_WITH_DB_PASSWORD"
    	db_name = "playersync"
    	Server_id = 2
    	sync_world = []
    	sync_advancements = false
    	sync_chat = false
    	IsChatServer = false
    	ChatServerIP = "127.0.0.1"
    	ChatServerPort = 7900
    	use_legacy_serialization = false
    	item_placeholder_title_override = ""
    	item_placeholder_description_override = ""