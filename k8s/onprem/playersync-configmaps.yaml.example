# ============================================================
# PlayersSync mod 設定 ConfigMap テンプレート（3サーバー分）
#
# このファイルは例示用。DB パスワードを置換して保存:
#   k8s/onprem/playersync-configmaps.yaml  ← gitignore 済み
#
# 準備手順:
#   cp k8s/onprem/playersync-configmaps.yaml.example \
#      k8s/onprem/playersync-configmaps.yaml
#   # REPLACE_WITH_DB_PASSWORD を実際のパスワードに編集
#   rsync k8s/onprem/playersync-configmaps.yaml k3s-worker:~/k8s_manifests/
#   ssh k3s-worker "sudo kubectl apply -f ~/k8s_manifests/playersync-configmaps.yaml"
#
# ⚠️ 注意: playersync.toml のキー名は初回起動後に自動生成されるファイルで
#    確認して調整すること（mod バージョンによって差異がある場合あり）
# ============================================================
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: lobby-playersync-cm
  namespace: minecraft
  labels:
    app.kubernetes.io/name: minecraft-java
    app.kubernetes.io/component: lobby
    app.kubernetes.io/managed-by: kubectl
    env: prod
data:
  playersync.toml: |
    # PlayersSync 1.21.1-2.1.5 設定 (Lobby サーバー)
    [database]
      type = "MYSQL"
      host = "mariadb.minecraft-data.svc.cluster.local"
      port = 3306
      database = "playersync"
      username = "playersync"
      password = "REPLACE_WITH_DB_PASSWORD"

    [server]
      id = "lobby"

    [sync]
      inventory   = true
      armor       = true
      offhand     = true
      enderchest  = true
      experience  = true
      health      = true
      hunger      = true
      gamemode    = false   # サーバーごとに固定するため同期しない
      advancements = false  # サーバー固有の実績を保持
      statistics  = false

    [chat]
      # 既知バグ (1.21.1-2.1.5) のため無効化
      enabled = false

    [debug]
      logging = false
---
