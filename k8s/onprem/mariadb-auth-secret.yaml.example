# ============================================================
# MariaDB 認証 Secret テンプレート
# このファイルは例示用。実際の値を入力して以下の名前で保存:
#   k8s/onprem/mariadb-auth-secret.yaml  ← gitignore 済み
#
# apply 手順:
#   rsync k8s/onprem/mariadb-auth-secret.yaml k3s-worker:~/k8s_manifests/
#   ssh k3s-worker "sudo kubectl apply -f ~/k8s_manifests/mariadb-auth-secret.yaml"
# ============================================================
apiVersion: v1
kind: Secret
metadata:
  name: mariadb-auth-secret
  namespace: minecraft-data
  labels:
    app.kubernetes.io/name: mariadb
    app.kubernetes.io/component: database
    app.kubernetes.io/managed-by: kubectl
    env: prod
type: Opaque
stringData:
  # Bitnami MariaDB Chart が期待するキー名 (変更禁止)
  mariadb-root-password: "REPLACE_WITH_ROOT_PASSWORD"
  mariadb-password: "REPLACE_WITH_PLAYERSYNC_PASSWORD"
  mariadb-replication-password: ""
