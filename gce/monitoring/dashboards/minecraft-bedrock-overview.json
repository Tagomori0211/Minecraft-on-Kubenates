        "overrides": []
      }
    },
    {
      "type": "stat",
      "id": 3,
      "title": "応答時間 (UDP Ping)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "minecraft_status_response_time_seconds{component=\"bedrock\"}",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "orange", "value": 1.0 },
              { "color": "red", "value": 2.0 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "id": 4,
      "title": "サーバー状態",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "minecraft_status_healthy{component=\"bedrock\"}",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "name",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP & HEALTHY", "color": "green" } } }
          ],
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "type": "row",
      "id": 101,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "title": "Bedrock サーバー詳細",
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "id": 10,
      "title": "BDS サーバー",
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
      "targets": [
        { "refId": "A", "expr": "minecraft_status_healthy{component=\"bedrock\"}", "instant": true, "legendFormat": "状態" },
        { "refId": "B", "expr": "minecraft_status_players_online_count{component=\"bedrock\"}", "instant": true, "legendFormat": "オンラインプレイヤー" },
        { "refId": "C", "expr": "minecraft_status_players_max_count{component=\"bedrock\"}", "instant": true, "legendFormat": "最大プレイヤー" },
        { "refId": "D", "expr": "minecraft_status_response_time_seconds{component=\"bedrock\"}", "instant": true, "legendFormat": "応答時間 (秒)" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "A" },
            "properties": [
              { "id": "mappings", "value": [
                { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
              ] },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "red", "value": null }, { "color": "green", "value": 1 }
              ] } }
            ]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [
              { "id": "unit", "value": "none" },
              { "id": "decimals", "value": 0 }
            ]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "C" },
            "properties": [
              { "id": "unit", "value": "none" },
              { "id": "decimals", "value": 0 }
            ]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "D" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "decimals", "value": 3 },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 0.3 },
                { "color": "red", "value": 2.0 }
              ] } }
            ]
          }
        ]
      }
    },
    {
      "type": "stat",
      "id": 11,
      "title": "プレイヤー充足率",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "(minecraft_status_players_online_count{component=\"bedrock\"} / clamp_min(minecraft_status_players_max_count{component=\"bedrock\"}, 1)) * 100",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "gauge",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0,
          "max": 100,
          "min": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "orange", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "id": 12,
      "title": "サーバーバージョン",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "minecraft_status_version{component=\"bedrock\"}",
          "instant": true,
          "legendFormat": "{{server_version}}"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/^server_version$/", "values": false },
        "textMode": "name",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      }
    },
    {
      "type": "row",
      "id": 102,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 },
      "title": "プレイヤー数 / 応答時間 推移",
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 20,
      "title": "オンラインプレイヤー数 (時系列)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "minecraft_status_players_online_count{component=\"bedrock\"}",
          "legendFormat": "Bedrock プレイヤー数"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 3,
            "fillOpacity": 20,
            "showPoints": "never",
            "stacking": { "mode": "none" }
          },
          "color": { "mode": "fixed", "fixedColor": "#6ED0E0" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max", "mean"] },
        "tooltip": { "mode": "single" }
      }
    },
    {
      "type": "timeseries",
      "id": 21,
      "title": "応答時間 + CPU 相関 (時系列)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "minecraft_status_response_time_seconds{component=\"bedrock\"}",
          "legendFormat": "応答時間"
        },
        {
          "refId": "B",
          "expr": "rate(container_cpu_usage_seconds_total{namespace=\"minecraft\",pod=~\"deploy-bedrock-.*\",container!=\"\",container!=\"POD\"}[3m])",
          "legendFormat": "CPU Rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 3,
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "A" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "decimals", "value": 4 },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 0.3 },
                { "color": "red", "value": 2.0 }
              ] } }
            ]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "decimals", "value": 2 }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "type": "row",
      "id": 103,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "title": "サーバー稼働状況 (Up/Down)",
      "collapsed": false,
      "panels": []
    },
    {
      "type": "state-timeline",
      "id": 30,
      "title": "BDS 稼働状態タイムライン",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "minecraft_status_healthy{component=\"bedrock\"}",
          "legendFormat": "Bedrock BDS"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 0, "fillOpacity": 80 },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
