    },
    {
      "type": "row",
      "id": 104,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "title": "リソース使用量 (BDS Pod)",
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 40,
      "title": "メモリ使用量 (BDS + サイドカー)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (container) (container_memory_working_set_bytes{namespace=\"minecraft\",pod=~\"deploy-bedrock-.*\",container!=\"\",container!=\"POD\"})",
          "legendFormat": "{{container}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "showPoints": "never",
            "stacking": { "mode": "stacked" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "bedrock" },
            "properties": [
              { "id": "displayName", "value": "BDS サーバー" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "mc-monitor" },
            "properties": [
              { "id": "displayName", "value": "mc-monitor (サイドカー)" }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "type": "timeseries",
      "id": 41,
      "title": "CPU 使用率 (BDS プロセス)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (container) (rate(container_cpu_usage_seconds_total{namespace=\"minecraft\",pod=~\"deploy-bedrock-.*\",container!=\"\",container!=\"POD\"}[5m]))",
          "legendFormat": "{{container}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never",
            "stacking": { "mode": "stacked" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "bedrock" },
            "properties": [
              { "id": "displayName", "value": "BDS サーバー" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "mc-monitor" },
            "properties": [
              { "id": "displayName", "value": "mc-monitor (サイドカー)" }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "type": "row",
      "id": 105,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "title": "オンプレノード リソース (k3s-worker)",
      "collapsed": false,
      "panels": []
    },
    {
      "type": "gauge",
      "id": 50,
      "title": "ノード メモリ使用率",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 37 },
      "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (sum(container_memory_working_set_bytes{kubernetes_io_hostname=\"k3s-worker\"}) / machine_memory_bytes{kubernetes_io_hostname=\"k3s-worker\"})",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "value",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "orange", "value": 85 },
              { "color": "red", "value": 95 }
            ]
          }
        }
      }
    },
    {
      "type": "gauge",
      "id": 51,
      "title": "ノード CPU 使用率",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 37 },
      "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(rate(container_cpu_usage_seconds_total{kubernetes_io_hostname=\"k3s-worker\", container!=\"\"}[5m])) / machine_cpu_cores{kubernetes_io_hostname=\"k3s-worker\"}",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "value",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "orange", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "id": 52,
      "title": "メモリ空き容量",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 37 },
      "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
      "targets": [
        {
          "refId": "A",
          "expr": "machine_memory_bytes{kubernetes_io_hostname=\"k3s-worker\"} - sum(container_memory_working_set_bytes{kubernetes_io_hostname=\"k3s-worker\"})",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 2147483648 },
              { "color": "yellow", "value": 5368709120 },
              { "color": "green", "value": 10737418240 }
