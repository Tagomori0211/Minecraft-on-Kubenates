    },
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 0,
    "links": [],
    "liveNow": false,
    "panels": [
        {
            "collapsed": false,
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 0
            },
            "id": 1,
            "panels": [],
            "title": "On-Premises Total Cluster Usage",
            "type": "row"
        },
        {
            "title": "Cluster overall CPU Usage (Cores)",
            "type": "timeseries",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 1
            },
            "targets": [
                {
                    "expr": "sum(rate(container_cpu_usage_seconds_total{container!=\"\", location=\"onprem\"}[5m]))",
                    "legendFormat": "Total CPU Cores"
                }
            ]
        },
        {
            "title": "Cluster overall Memory Usage (%)",
            "type": "gauge",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 1
            },
            "targets": [
                {
                    "expr": "sum(container_memory_usage_bytes{container!=\"\", location=\"onprem\"}) / (64*1024*1024*1024)",
                    "legendFormat": "Total Memory %"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "mappings": [],
                    "max": 1,
                    "min": 0,
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "orange",
                                "value": 0.8
                            },
                            {
                                "color": "red",
                                "value": 0.9
                            }
                        ]
                    },
                    "unit": "percentunit"
                },
                "overrides": []
            }
        },
        {
            "collapsed": false,
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 9
            },
            "id": 4,
            "panels": [],
            "title": "Per-Pod Resource Usage",
            "type": "row"
        },
        {
            "title": "Pod CPU Usage (Cores)",
            "type": "timeseries",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": {
                "h": 10,
                "w": 12,
                "x": 0,
                "y": 10
            },
            "targets": [
                {
                    "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=~\"^$namespace$\", pod=~\"^$pod$\", container!=\"\", location=\"onprem\"}[5m])) by (pod)",
                    "legendFormat": "{{pod}}"
                }
            ],
            "transformations": [
                {
                    "id": "renameByRegex",
                    "options": {
                        "regex": "deploy-([a-zA-Z0-9]+)-.*",
                        "renamePattern": "$1"
                    }
                },
                {
                    "id": "renameByRegex",
                    "options": {
                        "regex": "([a-zA-Z0-9-]+?)-[a-z0-9]{8,10}-[a-z0-9]{5}",
                        "renamePattern": "$1"
                    }
                }
            ]
        },
        {
            "title": "Pod Memory Usage (%)",
            "type": "timeseries",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": {
                "h": 10,
                "w": 12,
                "x": 12,
                "y": 10
            },
            "targets": [
                {
                    "expr": "sum(container_memory_usage_bytes{namespace=~\"^$namespace$\", pod=~\"^$pod$\", container!=\"\", location=\"onprem\"}) by (pod) / (64*1024*1024*1024)",
                    "legendFormat": "{{pod}}"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "mappings": [],
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "orange",
                                "value": 0.8
                            },
                            {
                                "color": "red",
                                "value": 0.9
                            }
                        ]
                    },
                    "unit": "percentunit"
                },
                "overrides": []
            },
            "transformations": [
                {
                    "id": "renameByRegex",
                    "options": {
                        "regex": "deploy-([a-zA-Z0-9]+)-.*",
                        "renamePattern": "$1"
                    }
                },
                {
                    "id": "renameByRegex",
                    "options": {
                        "regex": "([a-zA-Z0-9-]+?)-[a-z0-9]{8,10}-[a-z0-9]{5}",
                        "renamePattern": "$1"
                    }
                }
            ]
        }
    ],
    "templating": {
        "list": [
            {
                "allValue": ".*",
                "current": {
                    "selected": true,
                    "text": [
                        "All"
                    ],
                    "value": [
